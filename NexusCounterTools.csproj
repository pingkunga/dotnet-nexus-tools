<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>nexus-component-counter</ToolCommandName>
    <PackageId>Nexus.ComponentCounter.Tool</PackageId>
    <Version>1.0.0</Version>
    <Authors>Chatri Ngambenchawong</Authors>
    <Description>Counts components in Nexus repositories through the Nexus REST API.</Description>
  </PropertyGroup>

</Project>
